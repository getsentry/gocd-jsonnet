                           "STAGE_VAR": "stage-customer-1"
                        },
                        "tasks": [
                           {
                              "script": "./deploy.sh --region=customer-1"
                           }
                        ]
                     },
                     "deploy-customer-2": {
                        "environment_variables": {
                           "JOB_VAR": "job-customer-2",
