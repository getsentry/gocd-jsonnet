                           "STAGE_VAR": "stage-customer-2"
                        },
                        "tasks": [
                           {
                              "script": "./deploy.sh --region=customer-2"
                           }
                        ]
                     },
                     "deploy-customer-4": {
                        "environment_variables": {
                           "JOB_VAR": "job-customer-4",
                           "PIPELINE_VAR": "pipeline-customer-4",
                           "SHARED_VAR_JOB": "from-job",
                           "STAGE_VAR": "stage-customer-4"
                        },
                        "tasks": [
                           {
                              "script": "./deploy.sh --region=customer-4"
