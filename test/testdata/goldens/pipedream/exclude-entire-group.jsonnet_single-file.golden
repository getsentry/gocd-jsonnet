{
   "format_version": 10,
   "pipelines": {
      "deploy-example-de": {
         "display_order": 3,
         "group": "example",
         "materials": {
            "deploy-example-s4s-pipeline-complete": {
               "pipeline": "deploy-example-s4s",
               "stage": "pipeline-complete"
            },
            "example_repo": {
               "branch": "master",
               "destination": "example",
               "git": "git@github.com:getsentry/example.git"
            }
         },
         "stages": [
            {
               "deploy": {
                  "jobs": {
                     "deploy-de": {
                        "elastic_profile_id": "example",
                        "tasks": [
                           {
                              "script": "./deploy.sh --region=de"
                           }
                        ]
                     }
                  }
               }
            },
            {
               "pipeline-complete": {
                  "jobs": {
                     "pipeline-complete": {
                        "tasks": [
                           {
                              "exec": {
                                 "command": true
                              }
                           }
                        ]
                     }
                  }
               }
            }
         ]
      },
      "deploy-example-s4s": {
         "display_order": 2,
         "group": "example",
         "materials": {
            "example_repo": {
               "branch": "master",
               "destination": "example",
               "git": "git@github.com:getsentry/example.git"
            }
         },
         "stages": [
            {
               "deploy": {
                  "jobs": {
                     "deploy-s4s": {
                        "elastic_profile_id": "example",
                        "tasks": [
                           {
                              "script": "./deploy.sh --region=s4s"
                           }
                        ]
                     },
                     "deploy-s4s2": {
                        "elastic_profile_id": "example",
                        "tasks": [
                           {
                              "script": "./deploy.sh --region=s4s2"
                           }
                        ]
                     }
                  }
               }
            },
            {
               "pipeline-complete": {
                  "jobs": {
                     "pipeline-complete": {
                        "tasks": [
                           {
                              "exec": {
                                 "command": true
                              }
                           }
                        ]
                     }
                  }
               }
            }
         ]
      },
      "deploy-example-us": {
         "display_order": 4,
         "group": "example",
         "materials": {
            "deploy-example-de-pipeline-complete": {
               "pipeline": "deploy-example-de",
               "stage": "pipeline-complete"
            },
            "example_repo": {
               "branch": "master",
               "destination": "example",
               "git": "git@github.com:getsentry/example.git"
            }
         },
         "stages": [
            {
               "deploy": {
                  "jobs": {
                     "deploy-us": {
                        "elastic_profile_id": "example",
                        "tasks": [
                           {
                              "script": "./deploy.sh --region=us"
                           }
                        ]
                     }
                  }
               }
            },
            {
               "pipeline-complete": {
                  "jobs": {
                     "pipeline-complete": {
                        "tasks": [
                           {
                              "exec": {
                                 "command": true
                              }
                           }
                        ]
                     }
                  }
               }
            }
         ]
      }
   }
}
