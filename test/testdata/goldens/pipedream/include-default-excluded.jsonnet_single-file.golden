{
   "format_version": 10,
   "pipelines": {
      "deploy-example-control": {
         "display_order": 6,
         "environment_variables": {
            "PIPEDREAM_GROUP_REGIONS": "control"
         },
         "group": "example",
         "materials": {
            "deploy-example-us2-pipeline-complete": {
               "pipeline": "deploy-example-us2",
               "stage": "pipeline-complete"
            },
            "example_repo": {
               "branch": "master",
               "destination": "example",
               "git": "git@github.com:getsentry/example.git"
            }
         },
         "stages": [
            {
               "deploy": {
                  "jobs": {
                     "deploy": {
                        "elastic_profile_id": "example",
                        "tasks": [
                           {
                              "script": "./deploy.sh --region=control"
                           }
                        ]
                     }
                  }
               }
            },
            {
               "pipeline-complete": {
                  "fetch_materials": false,
                  "jobs": {
                     "pipeline-complete": {
                        "tasks": [
                           {
                              "exec": {
                                 "command": true
                              }
                           }
                        ]
                     }
                  }
               }
            }
         ]
      },
      "deploy-example-de": {
