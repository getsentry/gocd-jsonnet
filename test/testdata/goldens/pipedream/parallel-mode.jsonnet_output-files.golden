   "deploy-example.yaml": {
      "format_version": 10,
      "pipelines": {
         "deploy-example": {
            "display_order": 0,
            "group": "example",
            "lock_behavior": "unlockWhenFinished",
            "materials": {
               "init_repo": {
                  "branch": "master",
                  "destination": "init",
                  "git": "git@github.com:getsentry/init.git"
               }
            },
            "stages": [
               {
                  "pipeline-complete": {
                     "approval": {
                        "type": "manual"
                     },
                     "fetch_materials": false,
                     "jobs": {
                        "pipeline-complete": {
                           "tasks": [
                              {
                                 "exec": {
                                    "command": true
                                 }
                              }
                           ]
                        }
                     }
                  }
               }
            ]
         }
      }
   }
