{
   "deploy-example-de.yaml": {
      "format_version": 10,
      "pipelines": {
         "deploy-example-de": {
            "display_order": 3,
            "group": "example",
            "materials": {
               "deploy-example-pipeline-complete": {
                  "pipeline": "deploy-example",
                  "stage": "pipeline-complete"
               },
               "example_repo": {
                  "branch": "master",
                  "destination": "example",
                  "git": "git@github.com:getsentry/example.git"
               }
            },
            "stages": [
               {
                  "deploy": {
                     "jobs": {
                        "deploy-de": {
                           "elastic_profile_id": "example",
                           "tasks": [
                              {
                                 "script": "./deploy.sh --region=de"
                              }
                           ]
                        }
                     }
                  }
               },
               {
                  "pipeline-complete": {
                     "fetch_materials": false,
                     "jobs": {
                        "pipeline-complete": {
                           "tasks": [
                              {
                                 "exec": {
                                    "command": true
                                 }
                              }
                           ]
                        }
                     }
                  }
               }
            ]
         }
      }
   },
