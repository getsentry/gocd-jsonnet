{
   "format_version": 10,
   "pipelines": {
      "deploy-example-de": {
         "display_order": 2,
         "environment_variables": {
            "PIPEDREAM_GROUP_REGIONS": "de"
         },
         "group": "example",
         "materials": {
            "example_repo": {
               "branch": "master",
               "destination": "example",
               "git": "git@github.com:getsentry/example.git"
            }
         },
         "stages": [
            {
               "diff": {
                  "jobs": {
                     "diff-de-west-de": {
                        "artifacts": [
                           {
                              "build": {
                                 "destination": "output",
                                 "source": "result"
                              }
                           }
                        ],
                        "elastic_profile_id": "example",
                        "environment_variables": {
                           "SENTRY_REGION": "de-west-de"
                        },
                        "tasks": [
                           {
                              "script": "./diff.sh --cell=de-west-de"
                           }
                        ]
                     },
                     "diff-de-west-nl": {
                        "artifacts": [
                           {
                              "build": {
                                 "destination": "output",
                                 "source": "result"
                              }
                           }
                        ],
                        "elastic_profile_id": "example",
                        "environment_variables": {
                           "SENTRY_REGION": "de-west-nl"
                        },
                        "tasks": [
                           {
                              "script": "./diff.sh --cell=de-west-nl"
                           }
                        ]
                     }
                  }
               }
            },
            {
               "apply": {
                  "jobs": {
                     "apply-de-west-de": {
                        "elastic_profile_id": "example",
                        "environment_variables": {
                           "SENTRY_REGION": "de-west-de"
                        },
                        "tasks": [
                           {
                              "fetch": {
                                 "destination": "artifacts",
                                 "job": "diff-de-west-de",
                                 "source": "output",
                                 "stage": "diff"
                              }
                           },
                           {
                              "script": "./apply.sh --cell=de-west-de"
                           }
                        ]
                     },
                     "apply-de-west-nl": {
                        "elastic_profile_id": "example",
                        "environment_variables": {
                           "SENTRY_REGION": "de-west-nl"
                        },
                        "tasks": [
                           {
                              "fetch": {
                                 "destination": "artifacts",
                                 "job": "diff-de-west-nl",
                                 "source": "output",
                                 "stage": "diff"
                              }
                           },
                           {
                              "script": "./apply.sh --cell=de-west-nl"
                           }
                        ]
                     }
                  }
               }
            },
            {
               "pipeline-complete": {
                  "fetch_materials": false,
                  "jobs": {
                     "pipeline-complete": {
                        "tasks": [
                           {
                              "exec": {
                                 "command": true
                              }
                           }
                        ]
                     }
                  }
               }
            }
         ]
      }
   }
}
